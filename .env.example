# Copy this file to .env for local use.
# Do not commit real secrets, tokens, or Codex auth material.

OPENAI_COMPAT_API_KEY=replace-me
OPENAI_COMPAT_HOST=127.0.0.1
OPENAI_COMPAT_PORT=8000
OPENAI_COMPAT_PUBLISHED_HOST=127.0.0.1
OPENAI_COMPAT_PUBLISHED_PORT=8000
OPENAI_COMPAT_LOG_LEVEL=INFO
OPENAI_COMPAT_LOG_FORMAT=text
OPENAI_COMPAT_DEBUG_LOGGING=false
OPENAI_COMPAT_LOG_PAYLOADS=false
OPENAI_COMPAT_LOG_UPSTREAM_BODY_LIMIT=4000
CODEX_OPENAI_SERVER_IMAGE=ghcr.io/joshuasundance-swca/codex_openai_server
CODEX_OPENAI_SERVER_IMAGE_VERSION=v0.1.0
CODEX_OPENAI_SERVER_PULL_POLICY=missing
# LOCAL_CODEX_HOME should point at the directory containing auth.json.
LOCAL_CODEX_HOME=~/.codex
